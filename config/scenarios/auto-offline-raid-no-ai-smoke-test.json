{
  "schemaVersion": 1,
  "name": "auto-offline-raid-no-ai-smoke-test",
  "description": "Launch SPT launcher/client, enter an offline Factory raid path, set practice raid AI amount to none, disable bosses, then run bounded movement/log/screenshot checks. Coordinates are calibrated for this workspace and remain percentage-based.",
  "requiresComputerUse": true,
  "requiresKeyboardMouseInput": true,
  "requiresClientLaunch": true,
  "allowRaidAutomation": true,
  "maxSeconds": 900,
  "maxInputActions": 200,
  "notes": [
    "At the practice-mode screen, the gear-labeled 游戏设置 control opens a secondary settings menu.",
    "Use this variant when you want reduced combat risk while visually testing map loading and movement.",
    "The no-AI submenu coordinates were verified on the configured SPT 4.0.13 Chinese UI at 2048x1152; use screenshots to recalibrate if resolution, language, or UI changes."
  ],
  "steps": [
    { "action": "wait", "condition": "wait_for_window", "timeoutSeconds": 120 },
    { "action": "focus_target_window" },
    { "action": "screenshot", "label": "launcher-or-client-visible" },
    { "action": "click_window_percent", "xPercent": 0.925, "yPercent": 0.905, "label": "launcher-start-game" },
    { "action": "wait", "seconds": 180 },
    { "action": "focus_target_window" },
    { "action": "screenshot", "label": "client-main-menu-candidate" },

    { "action": "click_window_percent", "xPercent": 0.50, "yPercent": 0.60, "label": "main-menu-escape-from-tarkov" },
    { "action": "wait", "seconds": 3 },
    { "action": "screenshot", "label": "after-main-menu-click" },
    { "action": "click_window_percent", "xPercent": 0.50, "yPercent": 0.88, "label": "select-pmc-next" },
    { "action": "wait", "seconds": 2 },
    { "action": "click_window_percent", "xPercent": 0.35, "yPercent": 0.36, "label": "select-factory-map" },
    { "action": "wait", "seconds": 1 },
    { "action": "click_window_percent", "xPercent": 0.50, "yPercent": 0.88, "label": "map-next-to-practice-settings" },
    { "action": "wait", "seconds": 2 },
    { "action": "screenshot", "label": "practice-settings-before-ai-zero" },

    { "action": "click_window_percent", "xPercent": 0.68, "yPercent": 0.27, "label": "open-game-settings-submenu" },
    { "action": "wait", "seconds": 1 },
    { "action": "screenshot", "label": "game-settings-submenu-open" },
    { "action": "click_window_percent", "xPercent": 0.385, "yPercent": 0.632, "label": "open-ai-amount-dropdown" },
    { "action": "wait", "seconds": 1 },
    { "action": "screenshot", "label": "ai-amount-dropdown-open" },
    { "action": "click_window_percent", "xPercent": 0.347, "yPercent": 0.686, "label": "select-ai-none" },
    { "action": "wait", "seconds": 1 },
    { "action": "click_window_percent", "xPercent": 0.269, "yPercent": 0.674, "label": "disable-bosses" },
    { "action": "wait", "seconds": 1 },
    { "action": "screenshot", "label": "verify-ai-none-and-bosses-off" },
    { "action": "click_window_percent", "xPercent": 0.755, "yPercent": 0.192, "label": "close-game-settings-submenu" },
    { "action": "wait", "seconds": 1 },

    { "action": "click_window_percent", "xPercent": 0.50, "yPercent": 0.88, "label": "practice-settings-next" },
    { "action": "wait", "seconds": 2 },
    { "action": "click_window_percent", "xPercent": 0.50, "yPercent": 0.88, "label": "insurance-next" },
    { "action": "wait", "seconds": 2 },
    { "action": "click_window_percent", "xPercent": 0.50, "yPercent": 0.88, "label": "confirm-ready-start-raid" },
    { "action": "wait", "seconds": 120 },
    { "action": "screenshot", "label": "raid-loaded-candidate" },

    { "action": "hold", "key": "w", "seconds": 1.0 },
    { "action": "hold", "key": "a", "seconds": 0.5 },
    { "action": "hold", "key": "d", "seconds": 0.5 },
    { "action": "move_mouse_relative", "x": 50, "y": 0 },
    { "action": "move_mouse_relative", "x": -50, "y": 0 },
    { "action": "screenshot", "label": "after-raid-movement" },
    { "action": "press", "key": "esc" },
    { "action": "collect_logs" },
    { "action": "analyze_logs" }
  ]
}
