{
  "schemaVersion": 1,
  "name": "auto-offline-raid-smoke-test",
  "description": "Launch SPT launcher/client, attempt to enter a local offline raid with bounded UI clicks, then perform a short movement/log/screenshot debug pass. Coordinates are percentage-based and may need calibration for your resolution/UI.",
  "requiresComputerUse": true,
  "requiresKeyboardMouseInput": true,
  "requiresClientLaunch": true,
  "allowRaidAutomation": true,
  "maxSeconds": 900,
  "maxInputActions": 180,
  "steps": [
    { "action": "wait", "condition": "wait_for_window", "timeoutSeconds": 120 },
    { "action": "focus_target_window" },
    { "action": "screenshot", "label": "launcher-or-client-visible" },
    { "action": "click_window_percent", "xPercent": 0.925, "yPercent": 0.905, "label": "launcher-start-game" },
    { "action": "wait", "seconds": 180 },
    { "action": "focus_target_window" },
    { "action": "screenshot", "label": "client-main-menu-candidate" },

    { "action": "click_window_percent", "xPercent": 0.50, "yPercent": 0.60, "label": "main-menu-escape-from-tarkov" },
    { "action": "wait", "seconds": 3 },
    { "action": "screenshot", "label": "after-main-menu-click" },
    { "action": "click_window_percent", "xPercent": 0.50, "yPercent": 0.88, "label": "next-or-ready-1" },
    { "action": "wait", "seconds": 2 },
    { "action": "click_window_percent", "xPercent": 0.35, "yPercent": 0.36, "label": "select-factory-map" },
    { "action": "wait", "seconds": 1 },
    { "action": "click_window_percent", "xPercent": 0.50, "yPercent": 0.88, "label": "next-or-ready-2" },
    { "action": "wait", "seconds": 2 },
    { "action": "click_window_percent", "xPercent": 0.50, "yPercent": 0.88, "label": "next-or-ready-3" },
    { "action": "wait", "seconds": 2 },
    { "action": "click_window_percent", "xPercent": 0.50, "yPercent": 0.88, "label": "ready-start-raid" },
    { "action": "wait", "seconds": 2 },
    { "action": "click_window_percent", "xPercent": 0.50, "yPercent": 0.88, "label": "confirm-ready-start-raid" },
    { "action": "wait", "seconds": 120 },
    { "action": "screenshot", "label": "raid-loaded-candidate" },

    { "action": "hold", "key": "w", "seconds": 1.0 },
    { "action": "hold", "key": "a", "seconds": 0.5 },
    { "action": "hold", "key": "d", "seconds": 0.5 },
    { "action": "move_mouse_relative", "x": 50, "y": 0 },
    { "action": "move_mouse_relative", "x": -50, "y": 0 },
    { "action": "screenshot", "label": "after-raid-movement" },
    { "action": "press", "key": "esc" },
    { "action": "collect_logs" },
    { "action": "analyze_logs" }
  ]
}
